---
import Eyebrow from '@components/ui/Eyebrow.astro';
import Reveal from '@components/motion/Reveal.astro';

interface FounderLetter {
  eyebrow: string;
  initial: string;
  name: string;
  role: string;
  image: string;
  paragraphs: string[];
}

const founders: FounderLetter[] = [
  {
    eyebrow: 'From the Founder',
    initial: 'S',
    name: 'Shalki Sharma',
    role: 'Founder, Shambhavi Innovation Lab',
    image: '/images/shalki.jpg',
    paragraphs: [
      "When I started Shambhavi Innovation Lab, I didn't want to build just another software company. I wanted to build a place where the best technology serves _everyone_ — not just the already-served.",
      'The finest mentors, the most advanced learning platforms, the most thoughtful HR systems, the smartest engineering tools — these have always existed. But only for some students, in some universities, in some companies. That is a problem worth solving, and we believe AI is how we solve it.',
      'Our mission is simple: help everyone learn, grow, and build — together.',
    ],
  },
  {
    eyebrow: 'From the Co-Founder',
    initial: 'A',
    name: 'Aman Verma',
    role: 'Co-Founder, Shambhavi Innovation Lab',
    image: '/images/aman.jpg',
    paragraphs: [
      'Since childhood, I have envisioned myself as a mentor — one who guides not by authority, but through understanding. My purpose has always been to reach beyond judgments and help others discover clarity, confidence, and meaning in their own stories.',
      'Through MUNs, workshops, and countless heartfelt interactions, I came to a realisation: mentorship is not about teaching _what_ to think, but _how_ to think — and how to become. That seed grew into Shambhavi Innovation Lab — a belief that every student, every professional, every builder, when guided with empathy and purpose, can become a star in their own journey.',
    ],
  },
];

function renderItalics(text: string): string {
  return text.replace(/_([^_]+)_/g, '<em class="italic font-light text-saffron-500">$1</em>');
}
---

<section class="section-pad bg-cream text-ink-primary relative" id="founders" aria-labelledby="founders-heading">
  <div class="container-page">
    <div class="max-w-3xl mb-16">
      <Reveal>
        <Eyebrow withLine={true}>Voices</Eyebrow>
      </Reveal>
      <Reveal delay={100}>
        <h2 id="founders-heading" class="mt-6 font-serif fraunces-display text-display-lg text-navy text-balance">
          Letters from <em class="italic font-light text-saffron-500">the founders.</em>
        </h2>
      </Reveal>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 md:gap-12">
      {founders.map((founder, i) => (
        <Reveal delay={i * 150}>
          <article class="h-full rounded-3xl bg-cream-50 border border-navy/8 p-8 md:p-12 flex flex-col">
            <div class="flex items-center gap-4 mb-6">
              <div class="relative w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden bg-cream-300 ring-2 ring-saffron-400/30 ring-offset-2 ring-offset-cream-50">
                <img
                  src={founder.image}
                  alt={`${founder.name}, ${founder.role}`}
                  width="80"
                  height="80"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
              </div>
              <div>
                <p class="eyebrow text-saffron-500">{founder.eyebrow}</p>
                <p class="mt-1 font-serif text-lg text-navy font-medium">{founder.name}</p>
                <p class="text-xs text-ink-muted">{founder.role}</p>
              </div>
            </div>

            <div aria-hidden="true" class="font-serif text-8xl text-saffron-400/20 leading-[0.5] -ml-2">“</div>

            <div class="mt-4 space-y-5 text-base md:text-lg leading-relaxed text-ink-secondary text-pretty">
              {founder.paragraphs.map((p) => (
                <p set:html={renderItalics(p)}></p>
              ))}
            </div>

            <div class="mt-8 pt-6 border-t border-navy/10 flex items-center gap-3">
              <div class="font-serif italic text-3xl text-navy">{founder.name.split(' ')[0]}</div>
              <span class="flex-1 h-px bg-navy/10"></span>
              <span class="text-xs font-mono uppercase tracking-wider text-ink-muted">{founder.initial}.S.</span>
            </div>
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
