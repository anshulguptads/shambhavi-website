---
import Eyebrow from '@components/ui/Eyebrow.astro';
import Button from '@components/ui/Button.astro';
import GradientOrb from '@components/motion/GradientOrb.astro';
---

<section class="relative overflow-hidden bg-navy-deepest text-onDark-primary grain-overlay min-h-[min(100svh,900px)] flex items-center pt-28 md:pt-32 pb-24 md:pb-32" id="hero" aria-labelledby="hero-title">
  {/* Ambient gradient orbs */}
  <GradientOrb class="-top-40 -right-20 md:-right-40 -z-0" color="saffron" size="lg" />
  <GradientOrb class="bottom-0 -left-40 -z-0" color="maroon" size="md" />

  {/* Grid pattern */}
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: linear-gradient(rgba(250,247,239,1) 1px, transparent 1px), linear-gradient(90deg, rgba(250,247,239,1) 1px, transparent 1px); background-size: 72px 72px;"
  >
  </div>

  <div class="container-page relative z-10">
    <div class="grid lg:grid-cols-[1.35fr_1fr] gap-12 lg:gap-16 xl:gap-24 items-center">

      {/* Copy */}
      <div class="order-2 lg:order-1">
        <div class="animate-fade-up" style="animation-delay: 80ms">
          <Eyebrow variant="dark" withLine={true}>
            AI that perceives. Not just predicts.
          </Eyebrow>
        </div>

        <h1
          id="hero-title"
          class="mt-6 md:mt-8 font-serif fraunces-display text-display-xl text-onDark-primary text-balance leading-[0.95]"
        >
          <span class="block animate-fade-up" style="animation-delay: 160ms">AI-native software</span>
          <span class="block animate-fade-up" style="animation-delay: 260ms">for how India <em class="font-light italic text-saffron-200">learns,</em></span>
          <span class="block animate-fade-up" style="animation-delay: 360ms"><em class="font-light italic text-saffron-200">works,</em> and <em class="font-light italic text-saffron-200">builds.</em></span>
        </h1>

        <p class="mt-7 md:mt-9 max-w-xl text-lead text-onDark-secondary text-pretty animate-fade-up" style="animation-delay: 480ms">
          We build AI-native platforms for schools, universities, enterprises, and engineering teams — headquartered in India, shipping to the world. Four products. One thesis: the best software should reach everyone, everywhere.
        </p>

        <div class="mt-9 md:mt-11 flex flex-col sm:flex-row gap-3 sm:gap-4 animate-fade-up" style="animation-delay: 580ms">
          <Button href="#platforms" variant="primary" size="lg">Explore our platforms</Button>
          <Button href="#contact" variant="ghost-dark" size="lg" icon="none">Request a demo</Button>
        </div>

        <div class="mt-14 md:mt-16 flex items-center gap-8 animate-fade-in" style="animation-delay: 820ms">
          <div class="text-xs font-medium uppercase tracking-eyebrow text-onDark-muted">Trusted by builders at</div>
          <div class="h-px flex-1 bg-cream/10"></div>
          <div class="flex items-center gap-6 text-onDark-muted text-sm font-serif italic">
            <span>Schools</span>
            <span class="text-saffron-300/40">·</span>
            <span>Universities</span>
            <span class="text-saffron-300/40">·</span>
            <span>Enterprises</span>
          </div>
        </div>
      </div>

      {/* Eye visual — radial-beam variant */}
      <div class="order-1 lg:order-2 relative flex justify-center lg:justify-end animate-fade-in" style="animation-delay: 340ms">
        <div class="relative w-full max-w-[360px] md:max-w-[440px] aspect-[4/3]">
          {/* Glow behind eye */}
          <div class="absolute inset-0 rounded-full bg-saffron-400/20 blur-3xl scale-75 animate-gentle-pulse"></div>

          <svg
            class="hero-eye relative w-full h-full"
            viewBox="0 0 160 120"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <defs>
              <radialGradient id="iris-gradient" cx="0.5" cy="0.45" r="0.5">
                <stop offset="0%" stop-color="#f5b556" />
                <stop offset="60%" stop-color="#d99133" />
                <stop offset="100%" stop-color="#b87627" />
              </radialGradient>
            </defs>

            {/* Eye outline — animated draw */}
            <path
              class="eye-outline"
              d="M 18 60 C 40 20, 120 20, 142 60 C 120 100, 40 100, 18 60 Z"
              stroke="#faf7ef"
              stroke-width="1.8"
              stroke-linejoin="round"
              fill="none"
              pathLength="1"
            />

            {/* Radial beams — 16 lines emanating from center to outline */}
            <g class="eye-beams" stroke="#faf7ef" stroke-width="0.55">
              {/* Horizontal + vertical + diagonals (8 main) */}
              <line x1="80" y1="60" x2="142" y2="60" class="beam" style="--d: 100ms" />
              <line x1="80" y1="60" x2="18" y2="60" class="beam" style="--d: 140ms" />
              <line x1="80" y1="60" x2="80" y2="22" class="beam" style="--d: 180ms" />
              <line x1="80" y1="60" x2="80" y2="98" class="beam" style="--d: 220ms" />
              <line x1="80" y1="60" x2="126" y2="30" class="beam beam-med" style="--d: 260ms" />
              <line x1="80" y1="60" x2="34" y2="30" class="beam beam-med" style="--d: 300ms" />
              <line x1="80" y1="60" x2="126" y2="90" class="beam beam-med" style="--d: 340ms" />
              <line x1="80" y1="60" x2="34" y2="90" class="beam beam-med" style="--d: 380ms" />
              {/* Intermediate 8 for the "radial net" density */}
              <line x1="80" y1="60" x2="138" y2="48" class="beam beam-thin" style="--d: 420ms" />
              <line x1="80" y1="60" x2="138" y2="72" class="beam beam-thin" style="--d: 440ms" />
              <line x1="80" y1="60" x2="22" y2="48" class="beam beam-thin" style="--d: 460ms" />
              <line x1="80" y1="60" x2="22" y2="72" class="beam beam-thin" style="--d: 480ms" />
              <line x1="80" y1="60" x2="108" y2="24" class="beam beam-thin" style="--d: 500ms" />
              <line x1="80" y1="60" x2="52" y2="24" class="beam beam-thin" style="--d: 520ms" />
              <line x1="80" y1="60" x2="108" y2="96" class="beam beam-thin" style="--d: 540ms" />
              <line x1="80" y1="60" x2="52" y2="96" class="beam beam-thin" style="--d: 560ms" />
            </g>

            {/* Concentric ring around the iris */}
            <circle class="eye-ring" cx="80" cy="60" r="26" fill="none" stroke="#faf7ef" stroke-width="0.5" stroke-opacity="0.35" stroke-dasharray="2 3" />

            {/* Iris with gradient */}
            <circle class="eye-iris" cx="80" cy="60" r="16" fill="url(#iris-gradient)" />

            {/* Iris inner ring */}
            <circle cx="80" cy="60" r="16" fill="none" stroke="#b87627" stroke-width="0.6" opacity="0.5" />

            {/* Pupil (tracks cursor) */}
            <circle class="eye-pupil" id="hero-pupil" cx="80" cy="60" r="5.5" fill="#1a1840" />

            {/* Highlight */}
            <circle cx="76" cy="56" r="1.8" fill="#faf7ef" opacity="0.9" />

            {/* Outer cardinal anchor dots */}
            <g fill="#faf7ef">
              <circle cx="18" cy="60" r="2.2" opacity="0.85" />
              <circle cx="142" cy="60" r="2.2" opacity="0.85" />
              <circle cx="80" cy="22" r="2.2" opacity="0.7" />
              <circle cx="80" cy="98" r="2.2" opacity="0.7" />
            </g>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-eye .eye-outline {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: draw-outline 1400ms cubic-bezier(0.22, 1, 0.36, 1) 400ms forwards;
  }

  .hero-eye .eye-beams .beam {
    opacity: 0;
    stroke-dasharray: 70;
    stroke-dashoffset: 70;
    animation: draw-beam 700ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(1000ms + var(--d, 0ms));
    stroke-opacity: 0.55;
  }
  .hero-eye .eye-beams .beam-med { stroke-opacity: 0.4; stroke-width: 0.45; }
  .hero-eye .eye-beams .beam-thin { stroke-opacity: 0.25; stroke-width: 0.35; }

  .hero-eye .eye-ring {
    opacity: 0;
    animation: fade-in-slow 800ms cubic-bezier(0.22, 1, 0.36, 1) 1700ms forwards;
    transform-origin: 80px 60px;
    animation-fill-mode: forwards;
  }

  .hero-eye .eye-iris {
    transform-origin: 80px 60px;
    transform: scale(0);
    animation: grow 600ms cubic-bezier(0.22, 1, 0.36, 1) 1800ms forwards;
  }

  @keyframes draw-outline {
    to { stroke-dashoffset: 0; }
  }

  @keyframes draw-beam {
    from { opacity: 0; stroke-dashoffset: 70; }
    to { opacity: 1; stroke-dashoffset: 0; }
  }

  @keyframes fade-in-slow {
    to { opacity: 1; }
  }

  @keyframes grow {
    to { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eye .eye-outline,
    .hero-eye .eye-beams .beam,
    .hero-eye .eye-ring,
    .hero-eye .eye-iris {
      animation: none !important;
      opacity: 1 !important;
      stroke-dashoffset: 0 !important;
      transform: scale(1) !important;
    }
    .hero-eye .eye-beams .beam { stroke-opacity: 0.55; }
    .hero-eye .eye-beams .beam-med { stroke-opacity: 0.4; }
    .hero-eye .eye-beams .beam-thin { stroke-opacity: 0.25; }
  }
</style>

<script>
  const eye = document.querySelector('.hero-eye') as SVGElement | null;
  const pupil = document.getElementById('hero-pupil') as unknown as SVGCircleElement | null;

  if (eye && pupil && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const centerCx = 80;
    const centerCy = 60;
    const maxOffset = 5;
    let targetX = centerCx;
    let targetY = centerCy;
    let curX = centerCx;
    let curY = centerCy;
    let rafId: number | null = null;

    const move = (clientX: number, clientY: number) => {
      const rect = eye.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const dx = clientX - cx;
      const dy = clientY - cy;
      const mag = Math.hypot(dx, dy) || 1;
      const norm = Math.min(mag / 600, 1);
      targetX = centerCx + (dx / mag) * maxOffset * norm;
      targetY = centerCy + (dy / mag) * maxOffset * norm;
    };

    const follow = () => {
      curX += (targetX - curX) * 0.1;
      curY += (targetY - curY) * 0.1;
      pupil.setAttribute('cx', curX.toFixed(2));
      pupil.setAttribute('cy', curY.toFixed(2));
      rafId = requestAnimationFrame(follow);
    };

    window.addEventListener('mousemove', (e) => move(e.clientX, e.clientY), { passive: true });
    follow();

    window.addEventListener('beforeunload', () => {
      if (rafId !== null) cancelAnimationFrame(rafId);
    });
  }
</script>
