---
import Eyebrow from '@components/ui/Eyebrow.astro';
import Reveal from '@components/motion/Reveal.astro';

const reasons = [
  {
    num: 'I',
    title: 'Two seconds to intervention.',
    body: 'When a student on AspiremsAI signals distress in their journal, the KIRAN helpline appears on their screen in under two seconds — before any human has read a word. A counsellor is alerted, a safety flag goes live on the admin dashboard. That is what AI-native means when it matters.',
    metric: '< 2s',
    metricLabel: 'crisis-to-intervention',
  },
  {
    num: 'II',
    title: '19 modules. 4 countries. One login.',
    body: 'SanaDeep runs payroll across India (PF, ESI, Form 16), the UAE (WPS), the UK (P60), and the US (W-2) from a single platform — with Arabic right-to-left support built in. Most enterprise HRMS companies treat multi-country as a roadmap. We treated it as the foundation.',
    metric: '4',
    metricLabel: 'country payroll engines',
  },
  {
    num: 'III',
    title: '3.9 lakh students, every year.',
    body: 'That is how many CS engineering students India admits annually — and most graduate without ever building a real model. NeuroLink gives each of them a live Concept DNA knowledge graph, a personalised lesson from every paper their professor uploads, and zero GPU infrastructure to manage.',
    metric: '3.9L',
    metricLabel: 'CS students per year',
  },
  {
    num: 'IV',
    title: '60–70% less QA effort.',
    body: 'That is how much faster InsightTest AI ships test coverage than hand-coded QA. Drag-and-drop builder, AI-generated cases, self-healing when your UI shifts. One platform for mobile, web, API, and analytics — instead of five.',
    metric: '60–70%',
    metricLabel: 'QA effort reduction',
  },
];
---

<section class="section-pad bg-navy-deepest text-onDark-primary grain-overlay relative overflow-hidden" id="why" aria-labelledby="why-heading">
  {/* Ambient accent */}
  <div
    aria-hidden="true"
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60rem] h-[60rem] rounded-full opacity-40 blur-3xl pointer-events-none"
    style="background: radial-gradient(circle, rgba(217, 145, 51, 0.1) 0%, transparent 60%)"
  >
  </div>

  <div class="container-page relative">
    <div class="max-w-3xl mx-auto text-center">
      <Reveal>
        <Eyebrow variant="dark" withLine={true} class="justify-center">Why Shambhavi</Eyebrow>
      </Reveal>
      <Reveal delay={100}>
        <h2 id="why-heading" class="mt-6 font-serif fraunces-display text-display-lg text-onDark-primary text-balance">
          Abstract is easy. <em class="italic font-light text-saffron-300">Specific is harder.</em> Four differences you can measure.
        </h2>
      </Reveal>
    </div>

    <div class="mt-16 md:mt-20 grid md:grid-cols-2 gap-5 md:gap-6 max-w-6xl mx-auto">
      {reasons.map((reason, i) => (
        <Reveal delay={i * 100}>
          <article class="group h-full rounded-2xl bg-cream/[0.04] border border-cream/10 p-8 md:p-10 transition-all duration-500 hover:bg-cream/[0.06] hover:border-saffron-400/30">
            <div class="flex items-start justify-between gap-6">
              <div class="text-xs font-mono text-saffron-300 font-semibold tracking-wider">{reason.num}</div>
              <div class="text-right">
                <div class="font-serif text-2xl md:text-3xl text-saffron-200 font-light tabular-nums">{reason.metric}</div>
                <div class="text-[10px] uppercase tracking-eyebrow text-onDark-muted mt-1">{reason.metricLabel}</div>
              </div>
            </div>

            <h3 class="mt-6 font-serif fraunces-display text-display-sm text-onDark-primary text-balance">
              {reason.title}
            </h3>

            <p class="mt-5 text-base leading-relaxed text-onDark-secondary text-pretty">
              {reason.body}
            </p>
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
