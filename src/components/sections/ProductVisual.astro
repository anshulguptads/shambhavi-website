---
interface Props {
  slug: 'aspirems' | 'neurolink' | 'sanadeep' | 'insighttest';
  variant?: 'light' | 'dark';
}
const { slug, variant = 'dark' } = Astro.props;

// SanaDeep modules — full forms, AI-powered marked with `ai: true`
const sanaModules = [
  { label: 'Core HR', ai: false },
  { label: 'Payroll', ai: true },
  { label: 'Time & Attendance', ai: false },
  { label: 'Leave Management', ai: false },
  { label: 'Talent Acquisition', ai: true },
  { label: 'Onboarding', ai: false },
  { label: 'Performance', ai: true },
  { label: 'Learning & Development', ai: false },
  { label: 'Compensation', ai: false },
  { label: 'Expense Management', ai: true },
  { label: 'Compliance', ai: true },
  { label: 'Analytics', ai: false },
];
---

{slug === 'aspirems' && (
  <div class="product-visual aspirems-visual h-full w-full bg-gradient-to-br from-navy-deep to-navy-elevated p-6 md:p-8 flex items-center justify-center">
    <div class="w-full max-w-sm space-y-3">
      <div class="flex flex-col gap-2.5">
        {/* Turn 1: Student asks in English */}
        <div class="chat-bubble self-end max-w-[82%] px-4 py-3 rounded-2xl rounded-br-md bg-cream/10 text-onDark-primary text-sm leading-relaxed border border-cream/5" style="animation-delay: 100ms">
          Sir, explain DNA structure?
        </div>

        {/* Turn 2: AI replies in Hindi */}
        <div class="chat-bubble self-start max-w-[94%] px-4 py-3 rounded-2xl rounded-bl-md bg-saffron-400 text-navy text-sm leading-relaxed font-medium" style="animation-delay: 900ms" lang="hi">
          <span class="font-devanagari">डॉक्टर बनना चाहते हैं? DNA को शरीर की रेसिपी-बुक समझिए — हर cell इसे पढ़कर जानती है क्या बनाना है.</span>
          <span class="inline-block ml-1">🧬</span>
        </div>

        {/* Turn 3: Student switches to Hinglish */}
        <div class="chat-bubble self-end max-w-[85%] px-4 py-3 rounded-2xl rounded-br-md bg-cream/10 text-onDark-primary text-sm leading-relaxed border border-cream/5" style="animation-delay: 1900ms">
          Thoda aur detail mein samjha dijiye?
        </div>

        {/* Turn 4: AI responds in Hinglish */}
        <div class="chat-bubble self-start max-w-[96%] px-4 py-3 rounded-2xl rounded-bl-md bg-saffron-400 text-navy text-sm leading-relaxed font-medium" style="animation-delay: 2800ms">
          Sure! DNA ke 4 bases hote hain — A, T, G, C. Yahi letters combine hoke har trait decide karte hain — aankhon ka colour, height, sab kuch.
        </div>

        {/* Typing indicator suggesting continued conversation */}
        <div class="chat-bubble self-start text-xs text-onDark-muted italic" style="animation-delay: 3700ms">
          <span class="inline-flex gap-1 items-center px-3 py-2 rounded-full bg-cream/5 border border-cream/5">
            <span class="typing-dot w-1.5 h-1.5 rounded-full bg-saffron-300"></span>
            <span class="typing-dot w-1.5 h-1.5 rounded-full bg-saffron-300"></span>
            <span class="typing-dot w-1.5 h-1.5 rounded-full bg-saffron-300"></span>
          </span>
        </div>
      </div>

      {/* Language chips */}
      <div class="chat-bubble flex items-center gap-2 mt-4 pt-4 border-t border-cream/5 text-[10px] uppercase tracking-eyebrow text-onDark-muted" style="animation-delay: 4100ms">
        <span class="w-1 h-1 rounded-full bg-saffron-300 animate-gentle-pulse"></span>
        <span>English</span>
        <span class="text-cream/20">·</span>
        <span>हिंदी</span>
        <span class="text-cream/20">·</span>
        <span>Hinglish</span>
        <span class="text-cream/20">·</span>
        <span>+10 more</span>
      </div>
    </div>
  </div>
)}

{slug === 'neurolink' && (
  <div class="product-visual neurolink-visual h-full w-full bg-gradient-to-br from-navy-deepest to-navy p-6 md:p-8 flex flex-col justify-center items-center relative overflow-hidden">
    {/* Ambient glow */}
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[340px] h-[340px] rounded-full blur-3xl" style="background: radial-gradient(circle, rgba(217, 145, 51, 0.2) 0%, transparent 65%);"></div>
    </div>

    <svg viewBox="0 0 400 340" class="w-full max-w-md h-auto relative" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <defs>
        <radialGradient id="nl-core" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0%" stop-color="#f5b556" />
          <stop offset="70%" stop-color="#d99133" />
          <stop offset="100%" stop-color="#b87627" />
        </radialGradient>
        <linearGradient id="nl-edge" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#d99133" stop-opacity="0.15" />
          <stop offset="50%" stop-color="#d99133" stop-opacity="0.8" />
          <stop offset="100%" stop-color="#d99133" stop-opacity="0.15" />
        </linearGradient>
      </defs>

      {/* Constellation ring — outer concepts */}
      <g class="nl-edges" stroke="#d99133" fill="none" stroke-linecap="round">
        {/* Center to inner ring */}
        <line x1="200" y1="170" x2="120" y2="90"  class="nl-edge" style="--d: 100ms" />
        <line x1="200" y1="170" x2="280" y2="90"  class="nl-edge" style="--d: 150ms" />
        <line x1="200" y1="170" x2="80"  y2="190" class="nl-edge" style="--d: 200ms" />
        <line x1="200" y1="170" x2="320" y2="190" class="nl-edge" style="--d: 250ms" />
        <line x1="200" y1="170" x2="140" y2="290" class="nl-edge" style="--d: 300ms" />
        <line x1="200" y1="170" x2="260" y2="290" class="nl-edge" style="--d: 350ms" />

        {/* Inner ring cross-connections (neural feel) */}
        <line x1="120" y1="90"  x2="280" y2="90"  class="nl-edge nl-edge-faint" style="--d: 450ms" />
        <line x1="80"  y1="190" x2="320" y2="190" class="nl-edge nl-edge-faint" style="--d: 500ms" />
        <line x1="120" y1="90"  x2="80"  y2="190" class="nl-edge nl-edge-faint" style="--d: 550ms" />
        <line x1="280" y1="90"  x2="320" y2="190" class="nl-edge nl-edge-faint" style="--d: 600ms" />
        <line x1="80"  y1="190" x2="140" y2="290" class="nl-edge nl-edge-faint" style="--d: 650ms" />
        <line x1="320" y1="190" x2="260" y2="290" class="nl-edge nl-edge-faint" style="--d: 700ms" />
        <line x1="140" y1="290" x2="260" y2="290" class="nl-edge nl-edge-faint" style="--d: 750ms" />

        {/* Animated traveling pulse along a key path */}
        <line x1="200" y1="170" x2="280" y2="90"  class="nl-signal" stroke="url(#nl-edge)" stroke-width="2" />
      </g>

      {/* Nodes with labels */}
      <g class="nl-nodes">
        {/* Inner ring: 6 core concepts */}
        <g class="nl-node nl-mastered" style="--d: 800ms">
          <circle cx="120" cy="90" r="16" fill="#d99133" />
          <circle cx="120" cy="90" r="16" fill="none" stroke="#f5b556" stroke-width="1" opacity="0.5" class="nl-halo" />
          <text x="120" y="93" text-anchor="middle" fill="#1a1840" font-family="Manrope, sans-serif" font-size="8" font-weight="600">Python</text>
        </g>
        <g class="nl-node nl-mastered" style="--d: 860ms">
          <circle cx="280" cy="90" r="16" fill="#d99133" />
          <text x="280" y="93" text-anchor="middle" fill="#1a1840" font-family="Manrope, sans-serif" font-size="7.5" font-weight="600">Linear Alg.</text>
        </g>
        <g class="nl-node nl-learning" style="--d: 920ms">
          <circle cx="80" cy="190" r="13" fill="#faf7ef" />
          <text x="80" y="193" text-anchor="middle" fill="#1a1840" font-family="Manrope, sans-serif" font-size="6.5" font-weight="600">Calculus</text>
        </g>
        <g class="nl-node nl-learning" style="--d: 980ms">
          <circle cx="320" cy="190" r="13" fill="#faf7ef" />
          <text x="320" y="193" text-anchor="middle" fill="#1a1840" font-family="Manrope, sans-serif" font-size="6.5" font-weight="600">Stats</text>
        </g>
        <g class="nl-node nl-locked" style="--d: 1040ms">
          <circle cx="140" cy="290" r="11" fill="none" stroke="#faf7ef" stroke-opacity="0.4" stroke-width="1.2" />
          <text x="140" y="293" text-anchor="middle" fill="#faf7ef" fill-opacity="0.6" font-family="Manrope, sans-serif" font-size="6" font-weight="500">Neural Nets</text>
        </g>
        <g class="nl-node nl-locked" style="--d: 1100ms">
          <circle cx="260" cy="290" r="11" fill="none" stroke="#faf7ef" stroke-opacity="0.4" stroke-width="1.2" />
          <text x="260" y="293" text-anchor="middle" fill="#faf7ef" fill-opacity="0.6" font-family="Manrope, sans-serif" font-size="5.8" font-weight="500">Transformers</text>
        </g>

        {/* Center: the student */}
        <g class="nl-center" style="--d: 0ms">
          <circle cx="200" cy="170" r="34" fill="url(#nl-core)" class="nl-core-pulse" />
          <circle cx="200" cy="170" r="34" fill="none" stroke="#f5b556" stroke-width="1" opacity="0.4" />
          <circle cx="200" cy="170" r="44" fill="none" stroke="#d99133" stroke-width="0.6" opacity="0.3" stroke-dasharray="2 3" />
          <text x="200" y="168" text-anchor="middle" fill="#1a1840" font-family="Fraunces, serif" font-size="10" font-weight="500" font-style="italic">You</text>
          <text x="200" y="180" text-anchor="middle" fill="#1a1840" font-family="Manrope, sans-serif" font-size="6" font-weight="500" opacity="0.7">Concept DNA</text>
        </g>
      </g>

      {/* Legend */}
      <g font-family="Manrope, sans-serif" font-size="7" letter-spacing="1.5">
        <g transform="translate(20, 322)">
          <circle cx="5" cy="0" r="3" fill="#d99133" />
          <text x="13" y="2.5" fill="#faf7ef" fill-opacity="0.75">MASTERED</text>
        </g>
        <g transform="translate(100, 322)">
          <circle cx="5" cy="0" r="3" fill="#faf7ef" />
          <text x="13" y="2.5" fill="#faf7ef" fill-opacity="0.75">LEARNING</text>
        </g>
        <g transform="translate(180, 322)">
          <circle cx="5" cy="0" r="3" fill="none" stroke="#faf7ef" stroke-opacity="0.5" />
          <text x="13" y="2.5" fill="#faf7ef" fill-opacity="0.75">NEXT</text>
        </g>
        <text x="380" y="324.5" fill="#faf7ef" fill-opacity="0.4" font-size="7" text-anchor="end" letter-spacing="3">LIVE GRAPH</text>
      </g>
    </svg>
  </div>
)}

{slug === 'sanadeep' && (
  <div class="product-visual sanadeep-visual h-full w-full bg-gradient-to-br from-[#3a0f20] via-[#2a0c1a] to-navy p-6 md:p-8 flex items-center justify-center relative overflow-hidden">
    {/* Sweeping scan line for ambient AI feel */}
    <div aria-hidden="true" class="sana-scan absolute inset-x-0 h-20 pointer-events-none"></div>

    <div class="grid grid-cols-3 gap-2.5 w-full max-w-sm">
      {sanaModules.map((mod, i) => (
        <div
          class:list={[
            'module-cell relative aspect-[5/4] flex items-center justify-center rounded-xl text-center leading-tight px-2 text-[10px] md:text-[11px] font-sans font-medium overflow-hidden',
            mod.ai
              ? 'bg-gradient-to-br from-saffron-400/20 to-saffron-400/5 text-saffron-100 border border-saffron-400/40'
              : 'bg-cream/5 text-onDark-secondary border border-cream/10',
          ]}
          style={`animation-delay: ${i * 60}ms`}
        >
          {mod.ai && (
            <span aria-hidden="true" class="absolute top-1.5 right-1.5 text-[7px] font-mono uppercase tracking-wider text-saffron-300 bg-saffron-400/20 px-1 py-px rounded-sm">AI</span>
          )}
          <span class="text-pretty">{mod.label}</span>
        </div>
      ))}
    </div>
  </div>
)}

{slug === 'insighttest' && (
  <div class="product-visual insighttest-visual h-full w-full bg-gradient-to-br from-navy-deep to-navy p-6 md:p-8 flex flex-col items-center justify-center gap-4 relative overflow-hidden">
    {/* Status header */}
    <div class="w-full max-w-xs flex items-center justify-between text-[10px] uppercase tracking-eyebrow text-onDark-muted">
      <span class="inline-flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-saffron-400 animate-gentle-pulse"></span>
        Test Run
      </span>
      <span class="font-mono">
        <span class="it-count-pass">0</span>
        <span class="text-onDark-faint">/36</span>
      </span>
    </div>

    <div class="grid grid-cols-6 gap-1.5 md:gap-2 w-full max-w-xs">
      {Array.from({ length: 36 }).map((_, i) => {
        const passPositions = [0, 1, 2, 7, 8, 9, 10, 14, 15, 16, 19, 20, 22, 23, 25, 28, 31, 32];
        const runPositions = [33, 34];
        const isPass = passPositions.includes(i);
        const isRun = runPositions.includes(i);
        return (
          <div
            class:list={[
              'matrix-cell aspect-square rounded-sm',
              isPass && 'cell-pass',
              isRun && 'cell-run',
              !isPass && !isRun && 'bg-cream/10',
            ]}
            data-pass={isPass ? 'true' : undefined}
            data-run={isRun ? 'true' : undefined}
            style={`animation-delay: ${i * 40}ms`}
          ></div>
        );
      })}
    </div>

    <div class="w-full max-w-xs flex items-center justify-between text-[9px] font-mono uppercase tracking-wider text-onDark-faint">
      <span>Mobile · Web · API · Analytics</span>
      <span class="text-saffron-300">self-healing</span>
    </div>
  </div>
)}

<style>
  /* ========== ASPIREMS CHAT ========== */
  .chat-bubble {
    opacity: 0;
    transform: translateY(8px);
    animation: slide-up 500ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: paused;
  }
  .product-visual.in-view .chat-bubble {
    animation-play-state: running;
  }
  .typing-dot {
    animation: typing 1.2s ease-in-out infinite;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }

  /* ========== NEUROLINK KNOWLEDGE GRAPH ========== */
  .neurolink-visual .nl-edge {
    stroke-width: 1.2;
    stroke-dasharray: 250;
    stroke-dashoffset: 250;
    opacity: 0;
    animation: nl-draw 900ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: paused;
    animation-delay: var(--d, 0ms);
    stroke-opacity: 0.45;
  }
  .neurolink-visual .nl-edge-faint { stroke-width: 0.7; stroke-opacity: 0.22; }

  .product-visual.in-view .nl-edge { animation-play-state: running; }

  .neurolink-visual .nl-signal {
    stroke-dasharray: 60 200;
    stroke-dashoffset: 260;
    animation: nl-signal 2.2s linear infinite;
    animation-play-state: paused;
    opacity: 0.9;
  }
  .product-visual.in-view .nl-signal { animation-play-state: running; }

  .neurolink-visual .nl-node {
    opacity: 0;
    transform-origin: center;
    transform: scale(0);
    animation: pop-in 450ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: paused;
    animation-delay: var(--d, 0ms);
  }
  .product-visual.in-view .nl-node { animation-play-state: running; }

  .neurolink-visual .nl-center {
    opacity: 0;
    transform-origin: 200px 170px;
    transform: scale(0.3);
    animation: grow-in 600ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: paused;
  }
  .product-visual.in-view .nl-center { animation-play-state: running; }

  .neurolink-visual .nl-core-pulse {
    animation: core-pulse 3s ease-in-out infinite;
    transform-origin: 200px 170px;
    animation-play-state: paused;
  }
  .product-visual.in-view .nl-core-pulse { animation-play-state: running; }

  .neurolink-visual .nl-halo {
    animation: halo-expand 2.5s ease-out infinite;
    transform-origin: 120px 90px;
    animation-play-state: paused;
  }
  .product-visual.in-view .nl-halo { animation-play-state: running; }

  /* ========== SANADEEP MODULES ========== */
  .module-cell {
    opacity: 0;
    transform: scale(0.9);
    animation: pop-in 400ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: paused;
  }
  .product-visual.in-view .module-cell {
    animation-play-state: running;
  }

  .sanadeep-visual .sana-scan {
    top: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(217, 145, 51, 0.08) 50%, transparent 100%);
    animation: sana-scan 4s linear infinite;
    animation-play-state: paused;
  }
  .product-visual.in-view .sana-scan { animation-play-state: running; }

  /* ========== INSIGHTTEST MATRIX ========== */
  .matrix-cell {
    opacity: 0;
    transform: scale(0.85);
    background-color: rgba(250, 247, 239, 0.1);
    animation: pop-in 400ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: paused;
  }
  .product-visual.in-view .matrix-cell { animation-play-state: running; }

  .matrix-cell.cell-pass {
    background-color: rgba(250, 247, 239, 0.1);
  }
  .product-visual.in-view .matrix-cell.cell-pass {
    animation: pop-in-then-pass 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: running;
  }

  .matrix-cell.cell-run {
    background-color: rgba(250, 247, 239, 0.5);
  }
  .product-visual.in-view .matrix-cell.cell-run {
    animation: pop-in-then-run 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards,
               gentle-pulse-cell 1.5s ease-in-out 1.3s infinite;
  }

  /* ========== KEYFRAMES ========== */
  @keyframes slide-up {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes typing {
    0%, 80%, 100% { opacity: 0.3; transform: translateY(0); }
    40% { opacity: 1; transform: translateY(-2px); }
  }
  @keyframes nl-draw {
    to { opacity: 1; stroke-dashoffset: 0; }
  }
  @keyframes nl-signal {
    to { stroke-dashoffset: -260; }
  }
  @keyframes pop-in {
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes grow-in {
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes core-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.85; }
  }
  @keyframes halo-expand {
    0% { r: 16; opacity: 0.6; }
    100% { r: 24; opacity: 0; }
  }
  @keyframes sana-scan {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(600%); }
  }
  @keyframes pop-in-then-pass {
    0% { opacity: 0; transform: scale(0.85); background-color: rgba(250, 247, 239, 0.1); }
    40% { opacity: 1; transform: scale(1); background-color: rgba(250, 247, 239, 0.1); }
    100% { opacity: 1; transform: scale(1); background-color: rgba(217, 145, 51, 0.9); }
  }
  @keyframes pop-in-then-run {
    0% { opacity: 0; transform: scale(0.85); background-color: rgba(250, 247, 239, 0.1); }
    40% { opacity: 1; transform: scale(1); background-color: rgba(250, 247, 239, 0.1); }
    100% { opacity: 1; transform: scale(1); background-color: rgba(250, 247, 239, 0.5); }
  }
  @keyframes gentle-pulse-cell {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.65; transform: scale(0.94); }
  }

  @media (prefers-reduced-motion: reduce) {
    .chat-bubble, .nl-node, .nl-edge, .nl-signal, .nl-center, .nl-core-pulse, .nl-halo,
    .module-cell, .matrix-cell, .sana-scan {
      opacity: 1 !important;
      transform: none !important;
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
    .matrix-cell.cell-pass { background-color: rgba(217, 145, 51, 0.9) !important; }
    .matrix-cell.cell-run { background-color: rgba(250, 247, 239, 0.5) !important; }
  }
</style>

<script>
  // Re-triggering observer: animations replay every time visual enters viewport
  const visuals = document.querySelectorAll('.product-visual');

  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const el = entry.target as HTMLElement;
          if (entry.isIntersecting) {
            // Force reflow by toggling the class off then on so CSS animations replay
            el.classList.remove('in-view');
            // eslint-disable-next-line @typescript-eslint/no-unused-expressions
            void el.offsetWidth;
            el.classList.add('in-view');

            // InsightTest live counter
            if (el.classList.contains('insighttest-visual')) {
              const counter = el.querySelector('.it-count-pass') as HTMLElement | null;
              if (counter) {
                counter.textContent = '0';
                const target = 18; // number of passPositions
                let cur = 0;
                const interval = window.setInterval(() => {
                  cur += 1;
                  if (counter) counter.textContent = String(cur);
                  if (cur >= target) window.clearInterval(interval);
                }, 60);
              }
            }
          } else {
            // Leaving viewport: reset so next entry re-plays
            el.classList.remove('in-view');
          }
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -80px 0px' }
    );
    visuals.forEach((v) => io.observe(v));
  } else {
    visuals.forEach((v) => v.classList.add('in-view'));
  }
</script>
