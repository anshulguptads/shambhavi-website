---
import { nav, site } from '@lib/site';

interface Props {
  /** 'over-dark' = starts transparent over a dark hero; swaps to solid cream when scrolled.
   *  'solid-light' = always solid cream bg with dark text (for pages without a dark hero). */
  mode?: 'over-dark' | 'solid-light';
}

const { mode = 'over-dark' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  data-mode={mode}
  data-scrolled="false"
  class:list={[
    'site-header fixed top-0 left-0 right-0 z-50',
    'transition-[background-color,border-color,backdrop-filter,box-shadow] duration-300 ease-out-expo',
    'border-b border-transparent',
    mode === 'solid-light' && 'solid-light',
  ]}
>
  <div class="container-page">
    <nav class="flex items-center justify-between py-4 md:py-5" aria-label="Primary navigation">
      {/* Logo */}
      <a
        href="/"
        class="hdr-logo flex items-center gap-2 font-serif text-xl md:text-[1.35rem] font-medium tracking-tight group"
        aria-label={`${site.shortName} — homepage`}
      >
        <span class="relative">
          <span class="hdr-wordmark">Shambhavi</span>
          <span aria-hidden="true" class="absolute -bottom-0.5 left-0 right-0 h-px bg-saffron-400 origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out-expo"></span>
        </span>
        <span class="hdr-dot">·</span>
        <span class="hdr-labs text-xs uppercase tracking-eyebrow font-sans font-medium">Labs</span>
      </a>

      {/* Desktop nav */}
      <ul class="hidden md:flex items-center gap-8 lg:gap-10 text-sm font-medium">
        {nav.primary.map((link) => {
          const linkPath = link.href.split('#')[0];
          const isActive =
            link.href === currentPath ||
            (linkPath && linkPath !== '/' && currentPath.startsWith(linkPath));
          return (
            <li>
              <a
                href={link.href}
                class:list={['hdr-link transition-colors duration-200 relative py-1', isActive && 'is-active']}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>

      {/* Desktop CTA */}
      <div class="hidden md:block">
        <a
          href={nav.cta.href}
          class="hdr-cta inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-all duration-300 ease-out-expo hover:shadow-glow"
        >
          {nav.cta.label}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      {/* Mobile menu toggle */}
      <button
        type="button"
        id="mobile-menu-toggle"
        class="hdr-toggle md:hidden relative flex flex-col items-center justify-center w-10 h-10 rounded-md transition-colors"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Open navigation menu"
      >
        <span class="sr-only">Toggle menu</span>
        <span class="menu-bar block w-5 h-[1.5px] bg-current transition-all duration-300 ease-out-expo" style="transform: translateY(-4px)"></span>
        <span class="menu-bar block w-5 h-[1.5px] bg-current transition-all duration-300 ease-out-expo" style="transform: translateY(0)"></span>
        <span class="menu-bar block w-5 h-[1.5px] bg-current transition-all duration-300 ease-out-expo" style="transform: translateY(4px)"></span>
      </button>
    </nav>
  </div>

  {/* Mobile menu panel */}
  <div
    id="mobile-menu"
    class="hdr-mobile-panel md:hidden fixed inset-x-0 top-[64px] bottom-0 z-40 pointer-events-none opacity-0 translate-y-2 transition-all duration-300 ease-out-expo"
    aria-hidden="true"
  >
    <div class="hdr-mobile-panel-inner h-full overflow-y-auto border-t backdrop-blur-xl">
      <div class="container-page py-8 flex flex-col gap-8">
        <div class="flex flex-col gap-1">
          <p class="eyebrow mb-4 hdr-mobile-eyebrow">Navigate</p>
          {nav.primary.map((link) => (
            <a href={link.href} class="hdr-mobile-link flex items-center justify-between py-4 border-b text-xl font-serif transition-colors">
              {link.label}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          ))}
        </div>

        <div class="flex flex-col gap-1">
          <p class="eyebrow mb-4 hdr-mobile-eyebrow">Platforms</p>
          {nav.products.map((product) => (
            <a href={product.href} class="hdr-mobile-sublink flex flex-col gap-0.5 py-3 border-b transition-colors">
              <span class="text-base font-medium">{product.label}</span>
              <span class="hdr-mobile-subdesc text-xs">{product.description}</span>
            </a>
          ))}
        </div>

        <a
          href={nav.cta.href}
          class="mt-4 inline-flex items-center justify-center gap-2 rounded-full bg-saffron-400 text-navy px-6 py-4 text-base font-medium shadow-glow"
        >
          {nav.cta.label}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 8h12m0 0L9 3m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  /* ========== OVER-DARK MODE ========== */
  /* Default (at top, over dark hero) — transparent bg, light text */
  .site-header[data-mode='over-dark'] {
    background-color: transparent;
    border-bottom-color: transparent;
    color: #faf7ef;
  }
  .site-header[data-mode='over-dark'] .hdr-wordmark { color: #faf7ef; }
  .site-header[data-mode='over-dark'] .hdr-dot { color: #e5a74c; }
  .site-header[data-mode='over-dark'] .hdr-labs { color: rgba(250, 247, 239, 0.68); }
  .site-header[data-mode='over-dark'] .hdr-link { color: rgba(250, 247, 239, 0.82); }
  .site-header[data-mode='over-dark'] .hdr-link:hover { color: #faf7ef; }
  .site-header[data-mode='over-dark'] .hdr-link.is-active { color: #e5a74c; }
  .site-header[data-mode='over-dark'] .hdr-cta { background: #d99133; color: #1a1840; }
  .site-header[data-mode='over-dark'] .hdr-cta:hover { background: #e5a74c; }
  .site-header[data-mode='over-dark'] .hdr-toggle { color: #faf7ef; }
  .site-header[data-mode='over-dark'] .hdr-toggle:hover { background: rgba(250, 247, 239, 0.1); }

  /* Scrolled — solid cream bg with dark text */
  .site-header[data-mode='over-dark'][data-scrolled='true'] {
    background-color: rgba(250, 247, 239, 0.88);
    border-bottom-color: rgba(26, 24, 64, 0.08);
    color: #1a1840;
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    backdrop-filter: blur(14px) saturate(140%);
    box-shadow: 0 1px 2px rgba(26, 24, 64, 0.03);
  }
  .site-header[data-mode='over-dark'][data-scrolled='true'] .hdr-wordmark { color: #1a1840; }
  .site-header[data-mode='over-dark'][data-scrolled='true'] .hdr-dot { color: #d99133; }
  .site-header[data-mode='over-dark'][data-scrolled='true'] .hdr-labs { color: #6b688f; }
  .site-header[data-mode='over-dark'][data-scrolled='true'] .hdr-link { color: #3c3a6b; }
  .site-header[data-mode='over-dark'][data-scrolled='true'] .hdr-link:hover { color: #1a1840; }
  .site-header[data-mode='over-dark'][data-scrolled='true'] .hdr-link.is-active { color: #b87627; }
  .site-header[data-mode='over-dark'][data-scrolled='true'] .hdr-cta { background: #1a1840; color: #faf7ef; }
  .site-header[data-mode='over-dark'][data-scrolled='true'] .hdr-cta:hover { background: #221f4a; }
  .site-header[data-mode='over-dark'][data-scrolled='true'] .hdr-toggle { color: #1a1840; }
  .site-header[data-mode='over-dark'][data-scrolled='true'] .hdr-toggle:hover { background: rgba(26, 24, 64, 0.05); }

  /* ========== SOLID-LIGHT MODE (always cream with dark text) ========== */
  .site-header[data-mode='solid-light'] {
    background-color: rgba(250, 247, 239, 0.92);
    border-bottom-color: rgba(26, 24, 64, 0.08);
    color: #1a1840;
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    backdrop-filter: blur(14px) saturate(140%);
  }
  .site-header[data-mode='solid-light'] .hdr-wordmark { color: #1a1840; }
  .site-header[data-mode='solid-light'] .hdr-dot { color: #d99133; }
  .site-header[data-mode='solid-light'] .hdr-labs { color: #6b688f; }
  .site-header[data-mode='solid-light'] .hdr-link { color: #3c3a6b; }
  .site-header[data-mode='solid-light'] .hdr-link:hover { color: #1a1840; }
  .site-header[data-mode='solid-light'] .hdr-link.is-active { color: #b87627; }
  .site-header[data-mode='solid-light'] .hdr-cta { background: #1a1840; color: #faf7ef; }
  .site-header[data-mode='solid-light'] .hdr-cta:hover { background: #221f4a; }
  .site-header[data-mode='solid-light'] .hdr-toggle { color: #1a1840; }
  .site-header[data-mode='solid-light'] .hdr-toggle:hover { background: rgba(26, 24, 64, 0.05); }

  /* ========== MOBILE PANEL ========== */
  /* Dark-mode mobile panel (when header is over dark hero) */
  .site-header[data-mode='over-dark'] .hdr-mobile-panel-inner {
    background: rgba(15, 13, 43, 0.98);
    border-top-color: rgba(250, 247, 239, 0.1);
  }
  .site-header[data-mode='over-dark'] .hdr-mobile-eyebrow { color: rgba(250, 247, 239, 0.68); }
  .site-header[data-mode='over-dark'] .hdr-mobile-link {
    color: #faf7ef;
    border-bottom-color: rgba(250, 247, 239, 0.1);
  }
  .site-header[data-mode='over-dark'] .hdr-mobile-link:hover { color: #e5a74c; }
  .site-header[data-mode='over-dark'] .hdr-mobile-sublink {
    color: rgba(250, 247, 239, 0.82);
    border-bottom-color: rgba(250, 247, 239, 0.05);
  }
  .site-header[data-mode='over-dark'] .hdr-mobile-sublink:hover { color: #e5a74c; }
  .site-header[data-mode='over-dark'] .hdr-mobile-subdesc { color: rgba(250, 247, 239, 0.68); }

  /* Light-mode mobile panel */
  .site-header[data-mode='solid-light'] .hdr-mobile-panel-inner {
    background: rgba(250, 247, 239, 0.98);
    border-top-color: rgba(26, 24, 64, 0.1);
  }
  .site-header[data-mode='solid-light'] .hdr-mobile-eyebrow { color: #6b688f; }
  .site-header[data-mode='solid-light'] .hdr-mobile-link {
    color: #1a1840;
    border-bottom-color: rgba(26, 24, 64, 0.1);
  }
  .site-header[data-mode='solid-light'] .hdr-mobile-link:hover { color: #b87627; }
  .site-header[data-mode='solid-light'] .hdr-mobile-sublink {
    color: #3c3a6b;
    border-bottom-color: rgba(26, 24, 64, 0.05);
  }
  .site-header[data-mode='solid-light'] .hdr-mobile-sublink:hover { color: #b87627; }
  .site-header[data-mode='solid-light'] .hdr-mobile-subdesc { color: #6b688f; }

  /* Focus-visible states */
  .site-header a:focus-visible,
  .site-header button:focus-visible {
    outline: 2px solid #d99133;
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const mode = header?.dataset.mode;

  // Scroll-based mode swap
  if (header && mode === 'over-dark') {
    const threshold = Math.max(80, window.innerHeight * 0.5);
    let ticking = false;
    const update = () => {
      const scrolled = window.scrollY > threshold;
      header.dataset.scrolled = scrolled ? 'true' : 'false';
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    };
    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update);
  }

  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bars = toggle?.querySelectorAll('.menu-bar') as NodeListOf<HTMLElement> | undefined;

  if (toggle && menu && bars) {
    let isOpen = false;
    const setOpen = (open: boolean) => {
      isOpen = open;
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
      menu.setAttribute('aria-hidden', String(!open));
      if (open) {
        menu.classList.remove('pointer-events-none', 'opacity-0', 'translate-y-2');
        menu.classList.add('opacity-100', 'translate-y-0');
        document.body.style.overflow = 'hidden';
        bars[0].style.transform = 'translateY(0) rotate(45deg)';
        bars[1].style.opacity = '0';
        bars[2].style.transform = 'translateY(0) rotate(-45deg)';
      } else {
        menu.classList.add('pointer-events-none', 'opacity-0', 'translate-y-2');
        menu.classList.remove('opacity-100', 'translate-y-0');
        document.body.style.overflow = '';
        bars[0].style.transform = 'translateY(-4px) rotate(0)';
        bars[1].style.opacity = '1';
        bars[2].style.transform = 'translateY(4px) rotate(0)';
      }
    };

    toggle.addEventListener('click', () => setOpen(!isOpen));
    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) setOpen(false);
    });
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768 && isOpen) setOpen(false);
    });
  }
</script>
