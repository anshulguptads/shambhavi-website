---
interface Props {
  href?: string;
  variant?: 'primary' | 'ghost' | 'ghost-dark' | 'link';
  size?: 'sm' | 'md' | 'lg';
  icon?: 'arrow' | 'external' | 'none';
  type?: 'button' | 'submit';
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  icon = 'arrow',
  type = 'button',
  class: className = '',
} = Astro.props;

const sizeClass = {
  sm: 'px-4 py-2 text-xs',
  md: 'px-6 py-3 text-sm',
  lg: 'px-7 py-4 text-base',
}[size];

const variantClass = {
  primary: 'bg-saffron-400 text-navy hover:bg-saffron-300 hover:shadow-glow',
  ghost: 'border border-navy/20 text-navy hover:border-navy/50 hover:bg-navy/5',
  'ghost-dark': 'border border-cream/20 text-cream hover:border-cream/50 hover:bg-cream/5',
  link: 'text-saffron-500 hover:text-saffron-600 underline-offset-4 hover:underline',
}[variant];

const base =
  variant === 'link'
    ? 'inline-flex items-center gap-1.5 font-medium transition-colors'
    : 'inline-flex items-center justify-center gap-2 rounded-full font-medium transition-all duration-300 ease-out-expo active:scale-[0.98]';

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  type={Tag === 'button' ? type : undefined}
  class:list={[base, variantClass, variant !== 'link' && sizeClass, className]}
>
  <slot />
  {icon === 'arrow' && (
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
      <path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}
  {icon === 'external' && (
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M3 3h6v6M3 9l6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}
</Tag>
