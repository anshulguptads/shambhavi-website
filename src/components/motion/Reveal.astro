---
interface Props {
  as?: string;
  delay?: number;
  class?: string;
  from?: 'up' | 'left' | 'right' | 'fade';
}

const { as: Tag = 'div', delay = 0, class: className = '', from = 'up' } = Astro.props;
const fromClass = {
  up: 'translate-y-4',
  left: '-translate-x-4',
  right: 'translate-x-4',
  fade: '',
}[from];
---

<Tag
  class:list={['reveal opacity-0 transition-all duration-700 ease-out-expo', fromClass, className]}
  style={`transition-delay: ${delay}ms`}
>
  <slot />
</Tag>

<script>
  const observe = () => {
    const els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.classList.remove('opacity-0', 'translate-y-4', '-translate-x-4', 'translate-x-4');
            el.classList.add('opacity-100', 'translate-y-0', 'translate-x-0');
            io.unobserve(el);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
    );
    els.forEach((el) => io.observe(el));
  };
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observe);
  } else {
    observe();
  }
</script>
