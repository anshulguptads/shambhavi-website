---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import Button from '@components/ui/Button.astro';
import Pill from '@components/ui/Pill.astro';
import Reveal from '@components/motion/Reveal.astro';
import GradientOrb from '@components/motion/GradientOrb.astro';
import ProductVisual from '@components/sections/ProductVisual.astro';
import CtaSection from '@components/sections/CtaSection.astro';
import { productSchema, breadcrumbSchema } from '@lib/seo';
import { site } from '@lib/site';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;
const { Content } = await product.render();
const slug = product.slug as 'aspirems' | 'neurolink' | 'sanadeep' | 'insighttest';

const canonicalUrl = `${site.url}/platforms/${product.slug}`;
const schemas = [
  productSchema({
    name: data.name,
    description: data.description,
    url: canonicalUrl,
    image: data.ogImage ? `${site.url}${data.ogImage}` : undefined,
  }),
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Platforms', url: `${site.url}/#platforms` },
    { name: data.name, url: canonicalUrl },
  ]),
];

if (data.faqs && data.faqs.length > 0) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: data.faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.a,
      },
    })),
  });
}

// Split name into first + emphasized last word
const nameWords = data.name.split(' ');
const nameFirst = nameWords.slice(0, -1).join(' ');
const nameLast = nameWords[nameWords.length - 1];
---

<PageLayout
  title={data.name}
  description={data.description}
  canonical={`/platforms/${product.slug}`}
  ogImage={data.ogImage}
  schemas={schemas}
  headerMode="over-dark"
>
  {/* Hero */}
  <section class="relative overflow-hidden bg-navy-deepest text-onDark-primary grain-overlay pt-32 md:pt-36 pb-20 md:pb-28">
    <GradientOrb class="-top-20 -right-40" color={data.accentColor === 'maroon' ? 'maroon' : 'saffron'} size="lg" />

    <div class="container-page relative">
      <Reveal>
        <nav aria-label="Breadcrumb" class="flex items-center gap-3 text-xs uppercase tracking-eyebrow text-onDark-muted mb-10">
          <a href="/" class="hover:text-saffron-300 transition-colors">Shambhavi</a>
          <span aria-hidden="true">/</span>
          <a href="/#platforms" class="hover:text-saffron-300 transition-colors">Platforms</a>
          <span aria-hidden="true">/</span>
          <span class="text-onDark-primary">{data.name}</span>
        </nav>
      </Reveal>

      <div class="grid lg:grid-cols-[1.15fr_1fr] gap-10 lg:gap-16 items-center">
        <div>
          <Reveal delay={100}>
            <div class="flex items-center gap-3 mb-6">
              <Pill variant="saffron">{data.eyebrow}</Pill>
              {data.status === 'active' && <Pill variant="outline-dark">Live</Pill>}
              {data.status === 'beta' && <Pill variant="outline-dark">In Pilot</Pill>}
              {data.status === 'coming-soon' && <Pill variant="outline-dark">Coming Soon</Pill>}
            </div>
          </Reveal>

          <Reveal delay={150}>
            <h1 class="font-serif fraunces-display text-display-xl text-onDark-primary text-balance leading-[1]">
              {nameFirst ? <>{nameFirst} </> : null}
              <em class="italic font-light text-saffron-300">{nameLast}</em>
            </h1>
          </Reveal>

          <Reveal delay={250}>
            <p class="mt-8 text-lead text-onDark-secondary text-pretty max-w-2xl">
              {data.tagline}
            </p>
          </Reveal>

          <Reveal delay={350}>
            <div class="mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4">
              <Button href={data.ctaHref} variant="primary" size="lg">{data.ctaLabel}</Button>
              <Button href="/#platforms" variant="ghost-dark" size="lg" icon="none">See all platforms</Button>
            </div>
          </Reveal>
        </div>

        {/* Visual */}
        <div class="relative min-h-[320px] md:min-h-[420px] rounded-3xl overflow-hidden border border-cream/10 animate-fade-in" style="animation-delay: 300ms">
          <ProductVisual slug={slug} />
        </div>
      </div>
    </div>
  </section>

  {/* Proof points bar */}
  {data.proofPoints && data.proofPoints.length > 0 && (
    <section class="bg-navy-deepest text-onDark-primary border-t border-cream/10 py-8 md:py-10">
      <div class="container-page">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-10">
          {data.proofPoints.map((point) => (
            <div class="flex flex-col items-center text-center md:items-start md:text-left gap-1">
              <span class="font-serif text-2xl md:text-3xl text-saffron-300 font-light tabular-nums leading-none">{point.metric}</span>
              <span class="text-[10px] md:text-xs uppercase tracking-eyebrow text-onDark-muted">{point.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* For whom */}
  <section class="py-16 md:py-20 bg-cream text-ink-primary border-b border-navy/5">
    <div class="container-page">
      <div class="max-w-4xl mx-auto text-center">
        <Reveal>
          <Eyebrow withLine={true} class="justify-center">Built For</Eyebrow>
        </Reveal>
        <Reveal delay={100}>
          <p class="mt-6 font-serif fraunces-display text-display-md text-navy text-balance">
            {data.forWhom}
          </p>
        </Reveal>
      </div>
    </div>
  </section>

  {/* Long description */}
  <section class="section-pad bg-cream text-ink-primary">
    <div class="container-page">
      <div class="grid lg:grid-cols-[1fr_2fr] gap-10 lg:gap-20">
        <Reveal>
          <Eyebrow withLine={true}>The Platform</Eyebrow>
        </Reveal>
        <Reveal delay={100}>
          <p class="font-serif fraunces-display text-display-sm text-navy text-balance leading-[1.25]">
            {data.longDescription}
          </p>
        </Reveal>
      </div>
    </div>
  </section>

  {/* Key capabilities */}
  <section class="section-pad bg-cream-100 text-ink-primary" aria-labelledby="capabilities-heading">
    <div class="container-page">
      <div class="max-w-3xl mb-14 md:mb-20">
        <Reveal>
          <Eyebrow withLine={true}>Capabilities</Eyebrow>
        </Reveal>
        <Reveal delay={100}>
          <h2 id="capabilities-heading" class="mt-6 font-serif fraunces-display text-display-lg text-navy text-balance">
            What makes <em class="italic font-light text-saffron-500">{data.name}</em> different.
          </h2>
        </Reveal>
      </div>

      <div class="grid md:grid-cols-2 gap-5 md:gap-6">
        {data.keyCapabilities.map((cap, i) => (
          <Reveal delay={(i % 2) * 100}>
            <article class="h-full rounded-2xl bg-cream-50 border border-navy/8 p-8 md:p-10 flex flex-col hover:shadow-lift hover:-translate-y-1 transition-all duration-500 ease-out-expo">
              <div class="w-10 h-10 rounded-xl bg-saffron-400/15 flex items-center justify-center mb-6 text-saffron-500">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M3 9l3.5 3.5L15 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <h3 class="font-serif text-xl md:text-2xl text-navy leading-snug">{cap.title}</h3>
              <p class="mt-3 text-base leading-relaxed text-ink-secondary text-pretty">{cap.description}</p>
            </article>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  {/* Deep dive — renders the full MDX body */}
  <section class="section-pad bg-cream text-ink-primary" aria-labelledby="deepdive-heading">
    <div class="container-page">
      <div class="max-w-3xl mb-12 md:mb-16">
        <Reveal>
          <Eyebrow withLine={true}>Deep Dive</Eyebrow>
        </Reveal>
        <Reveal delay={100}>
          <h2 id="deepdive-heading" class="mt-6 font-serif fraunces-display text-display-lg text-navy text-balance">
            Everything <em class="italic font-light text-saffron-500">{data.name}</em> does, in detail.
          </h2>
        </Reveal>
      </div>

      <div class="max-w-3xl mx-auto prose prose-lg article-body">
        <Content />
      </div>
    </div>
  </section>

  {/* Outcomes */}
  <section class="section-pad bg-navy-deepest text-onDark-primary grain-overlay relative" aria-labelledby="outcomes-heading">
    <GradientOrb class="bottom-0 right-0 translate-x-1/3" color="saffron" size="md" />

    <div class="container-page relative">
      <div class="max-w-3xl mx-auto text-center mb-14 md:mb-20">
        <Reveal>
          <Eyebrow variant="dark" withLine={true} class="justify-center">What Changes</Eyebrow>
        </Reveal>
        <Reveal delay={100}>
          <h2 id="outcomes-heading" class="mt-6 font-serif fraunces-display text-display-lg text-onDark-primary text-balance">
            The outcomes <em class="italic font-light text-saffron-300">you can expect.</em>
          </h2>
        </Reveal>
      </div>

      <div class="max-w-4xl mx-auto">
        <ul class="divide-y divide-cream/10">
          {data.outcomes.map((outcome, i) => (
            <Reveal delay={i * 60}>
              <li class="flex items-start gap-5 py-6 md:py-8 group">
                <span aria-hidden="true" class="shrink-0 w-8 h-8 md:w-10 md:h-10 rounded-full bg-saffron-400/15 text-saffron-300 flex items-center justify-center font-mono text-xs md:text-sm font-semibold tabular-nums">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <p class="flex-1 pt-1 font-serif text-xl md:text-2xl text-onDark-primary text-pretty leading-snug group-hover:text-saffron-200 transition-colors">
                  {outcome}
                </p>
              </li>
            </Reveal>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* FAQ */}
  {data.faqs && data.faqs.length > 0 && (
    <section class="section-pad bg-cream-100 text-ink-primary" aria-labelledby="faq-heading">
      <div class="container-page">
        <div class="max-w-3xl mx-auto mb-12 md:mb-16 text-center">
          <Reveal>
            <Eyebrow withLine={true} class="justify-center">Questions</Eyebrow>
          </Reveal>
          <Reveal delay={100}>
            <h2 id="faq-heading" class="mt-6 font-serif fraunces-display text-display-lg text-navy text-balance">
              Things people <em class="italic font-light text-saffron-500">usually ask.</em>
            </h2>
          </Reveal>
        </div>

        <div class="max-w-3xl mx-auto">
          <ul class="divide-y divide-navy/10">
            {data.faqs.map((faq, i) => (
              <Reveal delay={i * 60}>
                <li>
                  <details class="group py-5 md:py-6">
                    <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
                      <h3 class="font-serif text-lg md:text-xl text-navy leading-snug group-hover:text-saffron-500 transition-colors">
                        {faq.q}
                      </h3>
                      <span
                        aria-hidden="true"
                        class="shrink-0 mt-1 w-7 h-7 rounded-full border border-navy/20 flex items-center justify-center text-navy transition-all group-open:rotate-45 group-open:border-saffron-400 group-open:bg-saffron-400 group-open:text-navy"
                      >
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                          <path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                      </span>
                    </summary>
                    <div class="mt-4 max-w-2xl text-base leading-relaxed text-ink-secondary text-pretty">
                      {faq.a}
                    </div>
                  </details>
                </li>
              </Reveal>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}

  <CtaSection />
</PageLayout>

<style is:global>
  /* Typography for deep-dive MDX body on product pages */
  .article-body h2 {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    line-height: 1.15;
    color: #1a1840;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-variation-settings: 'SOFT' 40, 'WONK' 0, 'opsz' 72;
    text-wrap: balance;
  }
  .article-body h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.375rem;
    line-height: 1.3;
    color: #1a1840;
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .article-body h4 {
    font-family: 'Manrope', sans-serif;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #d99133;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.4rem;
  }
  .article-body p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #3c3a6b;
    margin-bottom: 1.1em;
    text-wrap: pretty;
  }
  .article-body p strong { color: #1a1840; font-weight: 600; }
  .article-body em { color: #1a1840; font-style: italic; font-weight: 300; }
  .article-body a {
    color: #b87627;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .article-body a:hover { color: #8f5a1c; }
  .article-body ul {
    list-style: none;
    padding-left: 0;
    margin: 1em 0;
  }
  .article-body ul li {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.6em;
    line-height: 1.7;
    color: #3c3a6b;
  }
  .article-body ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.75em;
    width: 0.85rem;
    height: 1px;
    background: #d99133;
  }
  .article-body ol {
    list-style: decimal;
    padding-left: 1.5rem;
    margin: 1em 0;
  }
  .article-body ol li {
    color: #3c3a6b;
    line-height: 1.7;
    margin-bottom: 0.5em;
  }
  .article-body blockquote {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    line-height: 1.4;
    color: #1a1840;
    font-style: italic;
    font-weight: 400;
    border-left: 3px solid #d99133;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-variation-settings: 'SOFT' 60, 'opsz' 72;
  }
  .article-body blockquote p { font-size: inherit; line-height: inherit; margin: 0; }
  .article-body hr {
    border: none;
    border-top: 1px solid rgba(26, 24, 64, 0.15);
    margin: 2.5rem 0;
  }
  .article-body code {
    background: #f4efe0;
    color: #1a1840;
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-weight: 500;
  }
  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 0.95rem;
  }
  .article-body table th,
  .article-body table td {
    padding: 0.75em 1em;
    text-align: left;
    border-bottom: 1px solid rgba(26, 24, 64, 0.1);
  }
  .article-body table th {
    font-weight: 600;
    color: #1a1840;
    background: #f4efe0;
  }
</style>
