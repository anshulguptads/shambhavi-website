---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import Button from '@components/ui/Button.astro';
import Pill from '@components/ui/Pill.astro';
import Reveal from '@components/motion/Reveal.astro';
import GradientOrb from '@components/motion/GradientOrb.astro';
import ProductVisual from '@components/sections/ProductVisual.astro';
import CtaSection from '@components/sections/CtaSection.astro';
import { productSchema, breadcrumbSchema } from '@lib/seo';
import { site } from '@lib/site';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;
const slug = data.slug as 'aspirems' | 'neurolink' | 'sanadeep' | 'insighttest';

const canonicalUrl = `${site.url}/platforms/${data.slug}`;
const schemas = [
  productSchema({
    name: data.name,
    description: data.description,
    url: canonicalUrl,
    image: data.ogImage ? `${site.url}${data.ogImage}` : undefined,
  }),
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Platforms', url: `${site.url}/#platforms` },
    { name: data.name, url: canonicalUrl },
  ]),
];

// Split name into first + emphasized last word
const nameWords = data.name.split(' ');
const nameFirst = nameWords.slice(0, -1).join(' ');
const nameLast = nameWords[nameWords.length - 1];
---

<PageLayout
  title={data.name}
  description={data.description}
  canonical={`/platforms/${data.slug}`}
  ogImage={data.ogImage}
  schemas={schemas}
  headerVariant="dark"
  transparentHeader={true}
>
  {/* Hero */}
  <section class="relative overflow-hidden bg-navy-deepest text-onDark-primary grain-overlay pt-32 md:pt-36 pb-20 md:pb-28">
    <GradientOrb class="-top-20 -right-40" color={data.accentColor === 'maroon' ? 'maroon' : 'saffron'} size="lg" />

    <div class="container-page relative">
      {/* Breadcrumb */}
      <Reveal>
        <nav aria-label="Breadcrumb" class="flex items-center gap-3 text-xs uppercase tracking-eyebrow text-onDark-muted mb-10">
          <a href="/" class="hover:text-saffron-300 transition-colors">Shambhavi</a>
          <span aria-hidden="true">/</span>
          <a href="/#platforms" class="hover:text-saffron-300 transition-colors">Platforms</a>
          <span aria-hidden="true">/</span>
          <span class="text-onDark-primary">{data.name}</span>
        </nav>
      </Reveal>

      <div class="grid lg:grid-cols-[1.15fr_1fr] gap-10 lg:gap-16 items-center">
        <div>
          <Reveal delay={100}>
            <div class="flex items-center gap-3 mb-6">
              <Pill variant="saffron">{data.eyebrow}</Pill>
              {data.status === 'active' && <Pill variant="outline-dark">Live</Pill>}
              {data.status === 'beta' && <Pill variant="outline-dark">In Pilot</Pill>}
              {data.status === 'coming-soon' && <Pill variant="outline-dark">Coming Soon</Pill>}
            </div>
          </Reveal>

          <Reveal delay={150}>
            <h1 class="font-serif fraunces-display text-display-xl text-onDark-primary text-balance leading-[1]">
              {nameFirst ? <>{nameFirst} </> : null}
              <em class="italic font-light text-saffron-300">{nameLast}</em>
            </h1>
          </Reveal>

          <Reveal delay={250}>
            <p class="mt-8 text-lead text-onDark-secondary text-pretty max-w-2xl">
              {data.tagline}
            </p>
          </Reveal>

          <Reveal delay={350}>
            <div class="mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4">
              <Button href={data.ctaHref} variant="primary" size="lg">{data.ctaLabel}</Button>
              <Button href="/#platforms" variant="ghost-dark" size="lg" icon="none">See all platforms</Button>
            </div>
          </Reveal>
        </div>

        {/* Visual */}
        <div class="relative min-h-[320px] md:min-h-[420px] rounded-3xl overflow-hidden border border-cream/10 animate-fade-in" style="animation-delay: 300ms">
          <ProductVisual slug={slug} />
        </div>
      </div>
    </div>
  </section>

  {/* For whom */}
  <section class="py-16 md:py-20 bg-cream text-ink-primary border-b border-navy/5">
    <div class="container-page">
      <div class="max-w-4xl mx-auto text-center">
        <Reveal>
          <Eyebrow withLine={true} class="justify-center">Built For</Eyebrow>
        </Reveal>
        <Reveal delay={100}>
          <p class="mt-6 font-serif fraunces-display text-display-md text-navy text-balance">
            {data.forWhom}
          </p>
        </Reveal>
      </div>
    </div>
  </section>

  {/* Long description */}
  <section class="section-pad bg-cream text-ink-primary">
    <div class="container-page">
      <div class="grid lg:grid-cols-[1fr_2fr] gap-10 lg:gap-20">
        <Reveal>
          <Eyebrow withLine={true}>The Platform</Eyebrow>
        </Reveal>
        <Reveal delay={100}>
          <p class="font-serif fraunces-display text-display-sm text-navy text-balance leading-[1.25]">
            {data.longDescription}
          </p>
        </Reveal>
      </div>
    </div>
  </section>

  {/* Key capabilities */}
  <section class="section-pad bg-cream-100 text-ink-primary" aria-labelledby="capabilities-heading">
    <div class="container-page">
      <div class="max-w-3xl mb-14 md:mb-20">
        <Reveal>
          <Eyebrow withLine={true}>Capabilities</Eyebrow>
        </Reveal>
        <Reveal delay={100}>
          <h2 id="capabilities-heading" class="mt-6 font-serif fraunces-display text-display-lg text-navy text-balance">
            What makes <em class="italic font-light text-saffron-500">{data.name}</em> different.
          </h2>
        </Reveal>
      </div>

      <div class="grid md:grid-cols-2 gap-5 md:gap-6">
        {data.keyCapabilities.map((cap, i) => (
          <Reveal delay={(i % 2) * 100}>
            <article class="h-full rounded-2xl bg-cream-50 border border-navy/8 p-8 md:p-10 flex flex-col hover:shadow-lift hover:-translate-y-1 transition-all duration-500 ease-out-expo">
              <div class="w-10 h-10 rounded-xl bg-saffron-400/15 flex items-center justify-center mb-6 text-saffron-500">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M3 9l3.5 3.5L15 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <h3 class="font-serif text-xl md:text-2xl text-navy leading-snug">{cap.title}</h3>
              <p class="mt-3 text-base leading-relaxed text-ink-secondary text-pretty">{cap.description}</p>
            </article>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  {/* Outcomes */}
  <section class="section-pad bg-navy-deepest text-onDark-primary grain-overlay relative" aria-labelledby="outcomes-heading">
    <GradientOrb class="bottom-0 right-0 translate-x-1/3" color="saffron" size="md" />

    <div class="container-page relative">
      <div class="max-w-3xl mx-auto text-center mb-14 md:mb-20">
        <Reveal>
          <Eyebrow variant="dark" withLine={true} class="justify-center">What Changes</Eyebrow>
        </Reveal>
        <Reveal delay={100}>
          <h2 id="outcomes-heading" class="mt-6 font-serif fraunces-display text-display-lg text-onDark-primary text-balance">
            The outcomes <em class="italic font-light text-saffron-300">you can expect.</em>
          </h2>
        </Reveal>
      </div>

      <div class="max-w-4xl mx-auto">
        <ul class="divide-y divide-cream/10">
          {data.outcomes.map((outcome, i) => (
            <Reveal delay={i * 80}>
              <li class="flex items-start gap-5 py-6 md:py-8 group">
                <span
                  aria-hidden="true"
                  class="shrink-0 w-8 h-8 md:w-10 md:h-10 rounded-full bg-saffron-400/15 text-saffron-300 flex items-center justify-center font-mono text-xs md:text-sm font-semibold tabular-nums"
                >
                  {String(i + 1).padStart(2, '0')}
                </span>
                <p class="flex-1 pt-1 font-serif text-xl md:text-2xl text-onDark-primary text-pretty leading-snug group-hover:text-saffron-200 transition-colors">
                  {outcome}
                </p>
              </li>
            </Reveal>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <CtaSection />
</PageLayout>
