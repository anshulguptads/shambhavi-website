---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import type { SeoProps } from '@lib/seo';

interface Props extends SeoProps {
  /** How the header behaves:
   *  - 'over-dark'  = starts transparent over a dark hero, swaps to cream when scrolled (default)
   *  - 'solid-light'= always solid cream with dark text (for pages with no dark hero) */
  headerMode?: 'over-dark' | 'solid-light';
  footerVariant?: 'light' | 'dark';
  schemas?: unknown[];
  theme?: 'light' | 'dark';
  bodyClass?: string;
}

const {
  headerMode = 'over-dark',
  footerVariant = 'dark',
  schemas,
  theme,
  bodyClass,
  ...seoProps
} = Astro.props;
---

<BaseLayout {...seoProps} schemas={schemas} theme={theme} bodyClass={bodyClass}>
  <Header mode={headerMode} />
  <main id="main-content" class="min-h-screen">
    <slot />
  </main>
  <Footer variant={footerVariant} />
</BaseLayout>
