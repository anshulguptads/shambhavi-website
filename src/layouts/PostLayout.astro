---
import PageLayout from './PageLayout.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { articleSchema, breadcrumbSchema } from '@lib/seo';
import { site } from '@lib/site';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data } = post;

const url = `${site.url}/journal/${post.slug}`;
const schemas = [
  articleSchema({
    title: data.title,
    description: data.description,
    url,
    image: data.ogImage ? `${site.url}${data.ogImage}` : undefined,
    publishDate: data.publishDate,
    updatedDate: data.updatedDate,
    author: data.author,
    tags: data.tags,
  }),
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Journal', url: `${site.url}/journal` },
    { name: data.title, url },
  ]),
];

const dateFormatted = data.publishDate.toLocaleDateString('en-IN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<PageLayout
  title={data.title}
  description={data.description}
  canonical={`/journal/${post.slug}`}
  ogImage={data.ogImage}
  ogType="article"
  publishedTime={data.publishDate.toISOString()}
  modifiedTime={(data.updatedDate ?? data.publishDate).toISOString()}
  author={data.author}
  tags={data.tags}
  schemas={schemas}
  headerVariant="dark"
  transparentHeader={true}
>
  {/* Reading progress bar */}
  <div
    id="reading-progress"
    aria-hidden="true"
    class="fixed top-0 left-0 right-0 h-[2px] z-[60] bg-saffron-400 origin-left scale-x-0 transition-transform duration-150"
  ></div>

  {/* Hero */}
  <header class="relative overflow-hidden bg-navy-deepest text-onDark-primary pt-32 md:pt-40 pb-20 md:pb-28 grain-overlay">
    <div
      aria-hidden="true"
      class="absolute top-0 right-0 w-[40rem] h-[40rem] rounded-full blur-3xl opacity-40 -translate-y-1/2 translate-x-1/3 pointer-events-none"
      style="background: radial-gradient(circle, rgba(217, 145, 51, 0.2), transparent 65%)"
    >
    </div>

    <div class="container-page relative max-w-4xl">
      <nav aria-label="Breadcrumb" class="flex items-center gap-3 text-xs uppercase tracking-eyebrow text-onDark-muted mb-10 animate-fade-up">
        <a href="/" class="hover:text-saffron-300 transition-colors">Shambhavi</a>
        <span aria-hidden="true">/</span>
        <a href="/journal" class="hover:text-saffron-300 transition-colors">Journal</a>
        <span aria-hidden="true">/</span>
        <span class="text-onDark-primary truncate max-w-[12rem]">{data.eyebrow ?? data.category ?? 'Essay'}</span>
      </nav>

      {data.category && (
        <p class="eyebrow text-saffron-300 mb-6 animate-fade-up" style="animation-delay: 80ms">{data.category}</p>
      )}

      <h1 class="font-serif fraunces-display text-display-xl text-onDark-primary text-balance leading-[1.02] animate-fade-up" style="animation-delay: 150ms">
        {data.title}
      </h1>

      <p class="mt-8 max-w-2xl text-lead text-onDark-secondary text-pretty animate-fade-up" style="animation-delay: 250ms">
        {data.description}
      </p>

      <div class="mt-12 flex flex-wrap items-center gap-5 text-xs uppercase tracking-eyebrow text-onDark-muted animate-fade-up" style="animation-delay: 350ms">
        <span class="text-onDark-primary font-medium">{data.author}</span>
        <span class="text-onDark-faint">·</span>
        <time datetime={data.publishDate.toISOString()}>{dateFormatted}</time>
        {data.readingTime && (
          <>
            <span class="text-onDark-faint">·</span>
            <span>{data.readingTime}</span>
          </>
        )}
      </div>
    </div>
  </header>

  {/* Article body */}
  <article class="bg-cream text-ink-primary section-pad">
    <div class="container-page">
      <div class="max-w-prose mx-auto prose prose-lg article-body">
        <slot />
      </div>
    </div>
  </article>

  {/* Footer meta */}
  <section class="bg-cream-100 border-t border-navy/10 py-16">
    <div class="container-page max-w-prose">
      {data.tags.length > 0 && (
        <div class="flex flex-wrap items-center gap-2 mb-10">
          <span class="eyebrow text-ink-muted mr-2">Tags</span>
          {data.tags.map((tag) => (
            <span class="text-xs px-3 py-1 rounded-full bg-cream-300 text-ink-secondary">{tag}</span>
          ))}
        </div>
      )}

      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <a href="/journal" class="inline-flex items-center gap-2 text-sm font-medium text-ink-primary hover:text-saffron-500 transition-colors">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M13 7H1m0 0l5-5M1 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          All essays
        </a>

        <a href="mailto:info@shambhavilabs.com?subject=Response%20to%20essay" class="inline-flex items-center gap-2 text-sm font-medium text-saffron-500 hover:text-saffron-600 transition-colors">
          Write to us
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</PageLayout>

<style is:global>
  .article-body {
    font-family: 'Manrope', ui-sans-serif, system-ui, sans-serif;
    color: #3c3a6b;
  }

  .article-body h1,
  .article-body h2,
  .article-body h3,
  .article-body h4 {
    font-family: 'Fraunces', ui-serif, Georgia, serif;
    color: #1a1840;
    font-weight: 400;
    letter-spacing: -0.02em;
    font-variation-settings: 'SOFT' 40, 'WONK' 0, 'opsz' 72;
  }

  .article-body h2 {
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    line-height: 1.15;
    margin-top: 3rem;
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .article-body h2::before {
    content: counter(heading-counter, upper-roman);
    counter-increment: heading-counter;
    display: block;
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #d99133;
    margin-bottom: 0.75rem;
  }

  .article-body {
    counter-reset: heading-counter;
  }

  .article-body h3 {
    font-size: 1.5rem;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .article-body p {
    font-size: 1.0625rem;
    line-height: 1.75;
    margin-bottom: 1.25em;
    text-wrap: pretty;
  }

  .article-body p.lead {
    font-family: 'Fraunces', ui-serif, Georgia, serif;
    font-size: clamp(1.25rem, 2.2vw, 1.5rem);
    line-height: 1.5;
    color: #1a1840;
    font-weight: 400;
    letter-spacing: -0.015em;
    margin-bottom: 1.5em;
    font-variation-settings: 'SOFT' 35, 'opsz' 72;
  }

  .article-body p.lead::first-letter {
    font-family: 'Fraunces', serif;
    font-size: 3.5em;
    float: left;
    line-height: 0.85;
    margin: 0.05em 0.1em 0 0;
    color: #d99133;
    font-weight: 400;
    font-style: italic;
  }

  .article-body p strong {
    color: #1a1840;
    font-weight: 600;
  }

  .article-body a {
    color: #b87627;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 200ms ease;
  }
  .article-body a:hover {
    color: #8f5a1c;
  }

  .article-body blockquote {
    font-family: 'Fraunces', ui-serif, Georgia, serif;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.4;
    color: #1a1840;
    font-style: italic;
    font-weight: 400;
    border-left: 3px solid #d99133;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-variation-settings: 'SOFT' 60, 'opsz' 72;
  }

  .article-body blockquote p {
    font-size: inherit;
    line-height: inherit;
    margin-bottom: 0;
  }

  .article-body ul {
    list-style: none;
    padding-left: 0;
    margin: 1.25em 0;
  }

  .article-body ul li {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.65em;
    line-height: 1.7;
  }

  .article-body ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 0.875rem;
    height: 1px;
    background: #d99133;
  }

  .article-body hr {
    border: none;
    border-top: 1px solid rgba(26, 24, 64, 0.15);
    margin: 3rem 0;
  }

  .article-body sup.fn {
    font-size: 0.72em;
  }

  .article-body sup.fn a {
    color: #d99133;
    text-decoration: none;
  }

  .article-body sup.fn a:hover {
    text-decoration: underline;
  }

  .article-body em {
    font-style: italic;
    color: #1a1840;
    font-weight: 300;
  }
</style>

<script>
  // Reading progress
  const progress = document.getElementById('reading-progress');
  if (progress) {
    const update = () => {
      const scrolled = window.scrollY;
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const pct = max > 0 ? Math.min(scrolled / max, 1) : 0;
      progress.style.transform = `scaleX(${pct})`;
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
  }
</script>
